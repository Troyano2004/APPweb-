# Configuracion de la conexion a PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/TU_NOMBRE_BD_AQUI
spring.datasource.username=TU_USUARIO_AQUI
spring.datasource.password=TU_PASSWORD_AQUI
spring.datasource.driver-class-name=org.postgresql.Driver

# Configuracion de Hibernate (JPA)
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.default_schema=public
# Migraciones de base de datos
spring.flyway.baseline-on-migrate=true


# ================================
# AZURE BLOB STORAGE
# ================================
# Reemplaza TU_ACCOUNT_NAME con el nombre de tu Storage Account (ej: storagetitulacion)
# Reemplaza TU_ACCOUNT_KEY con la key que aparece en "Access keys" del portal de Azure
# Reemplaza TU_CONTENEDOR con el nombre del container que creaste (ej: documentos)
azure.storage.connection-string=DefaultEndpointsProtocol=https;AccountName=TU_ACCOUNT_NAME_AQUI;AccountKey=TU_ACCOUNT_KEY_AQUI;EndpointSuffix=core.windows.net
azure.storage.container-name=TU_CONTENEDOR_AQUI


# ================================
# GROQ API
# ================================
# Obten tu key gratis en console.groq.com -> API Keys -> Create API Key
groq.api.url=https://api.groq.com/openai/v1/chat/completions
groq.api.key=TU_GROQ_API_KEY_AQUI


# ================================
# Hikari (POOL DEFAULT)
# ================================
spring.datasource.hikari.pool-name=POOL_DEFAULT

spring.datasource.hikari.maximum-pool-size=15
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.max-lifetime=1800000

# Identifica tu backend en PostgreSQL (pg_stat_activity.application_name)
spring.datasource.hikari.data-source-properties.ApplicationName=BACKEND_TITU_DEFAULT

# ================================
# JPA
# ================================

# ================================
# SESSION
# ================================
server.servlet.session.cookie.http-only=true
server.servlet.session.tracking-modes=cookie
server.servlet.session.cookie.same-site=lax


# ================================
# GEMINI API
# ================================
#gemini.api.key=TU_GEMINI_API_KEY_AQUI
gemini.api.url=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent

# IMPORTANTE: expira la sesion automaticamente
server.servlet.session.timeout=1m

# ================================
# MULTIPART (subida de archivos)
# ================================
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=22MB

spring.mail.host=smtp.gmail.com
spring.mail.port=465
spring.mail.username=TU_CORREO_AQUI@gmail.com
spring.mail.password=TU_APP_PASSWORD_AQUI
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.ssl.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000

# Remitente que veran los destinatarios
app.mail.from=TU_CORREO_AQUI@gmail.com
app.mail.from-name=Sistema de Titulacion UTEQ

# ================================
# GMAIL SMTP
# ================================
#spring.mail.host=smtp.gmail.com
#spring.mail.port=587
#spring.mail.username=
